{
  "manifest_version": 3,
  "name": "SafeSell",
  "version": "1.0.0",
  "description": "Detects scam listings on Carousell using semantic web search, reverse image search, and LLM reasoning.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://*.carousell.com/*",
    "https://api.openai.com/*",
    "https://api.exa.ai/*",
    "https://serpapi.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://carousell.com/p/*", "*://www.carousell.com/p/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "SafeSell",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.css", "sidebar.js"],
      "matches": ["*://*.carousell.com/*"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.openai.com https://api.exa.ai https://serpapi.com"
  }
}
