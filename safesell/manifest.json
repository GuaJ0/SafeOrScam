{
  "key": "",
  "manifest_version": 3,
  "name": "SafeOrScam",
  "version": "1.0.0",
  "description": "Detects scam listings on Carousell using semantic web search, reverse image search, and LLM reasoning.",
  "permissions": ["activeTab", "scripting", "storage", "identity"],
  "host_permissions": [
    "*://*.carousell.com/*",
    "*://*.carousell.sg/*",
    "*://*.carousell.com.my/*",
    "*://*.carousell.ph/*",
    "*://*.carousell.com.hk/*",
    "*://*.carousell.tw/*",
    "*://*.carousell.co.id/*",
    "https://api.openai.com/*",
    "https://api.exa.ai/*",
    "https://serpapi.com/*",
    "https://*.supabase.co/*",
    "https://api.github.com/*",
    "https://www.instagram.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://carousell.com/p/*",
        "*://www.carousell.com/p/*",
        "*://carousell.sg/p/*",
        "*://www.carousell.sg/p/*",
        "*://carousell.com.my/p/*",
        "*://www.carousell.com.my/p/*",
        "*://carousell.ph/p/*",
        "*://www.carousell.ph/p/*",
        "*://carousell.com.hk/p/*",
        "*://www.carousell.com.hk/p/*",
        "*://carousell.tw/p/*",
        "*://www.carousell.tw/p/*",
        "*://carousell.co.id/p/*",
        "*://www.carousell.co.id/p/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://carousell.sg/*",
        "*://www.carousell.sg/*",
        "*://carousell.com/*",
        "*://www.carousell.com/*"
      ],
      "exclude_matches": [
        "*://carousell.sg/p/*",
        "*://www.carousell.sg/p/*",
        "*://carousell.com/p/*",
        "*://www.carousell.com/p/*"
      ],
      "js": ["search-badges.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://carousell.sg/chat/*",
        "*://www.carousell.sg/chat/*",
        "*://carousell.com/chat/*",
        "*://www.carousell.com/chat/*"
      ],
      "js": ["chat-monitor.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "SafeOrScam",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.html", "sidebar.css", "sidebar.js", "search-badges.js", "chat-monitor.js", "onboarding.html", "onboarding.js", "supabase-client.js", "icons/logo.png"],
      "matches": [
        "*://*.carousell.com/*",
        "*://*.carousell.sg/*",
        "*://*.carousell.com.my/*",
        "*://*.carousell.ph/*",
        "*://*.carousell.com.hk/*",
        "*://*.carousell.tw/*",
        "*://*.carousell.co.id/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.openai.com https://api.exa.ai https://serpapi.com https://api.github.com https://www.instagram.com https://*.supabase.co https://*.carousell.com https://*.carousell.sg https://*.carousell.com.my https://*.carousell.ph https://*.carousell.com.hk https://*.carousell.tw https://*.carousell.co.id"
  }
}
